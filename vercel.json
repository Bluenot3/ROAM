{
  "version": 2,
  "buildCommand": "cd shot-app && npm install && npm run build",
  "outputDirectory": "shot-app/dist",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/screenshots/:path*", "destination": "/api/index" },
    { "source": "/((?!api|screenshots|assets|favicon)[^.]*)", "destination": "/" }
  ]
}
